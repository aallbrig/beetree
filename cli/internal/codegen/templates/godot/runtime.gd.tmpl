## Runs all children every tick. Fails if any child fails.
class BTParallel extends BTNode:
	var children: Array[BTNode] = []

	func _init(p_name: String, p_children: Array[BTNode] = []) -> void:
		super._init(p_name)
		children = p_children

	func tick(blackboard: BTBlackboard, delta: float) -> int:
		var any_running = false
		for child in children:
			var status = child.tick(blackboard, delta)
			if status == BTStatus.FAILURE:
				return BTStatus.FAILURE
			if status == BTStatus.RUNNING:
				any_running = true
		return BTStatus.RUNNING if any_running else BTStatus.SUCCESS


## Wraps a child node and modifies its behavior.
